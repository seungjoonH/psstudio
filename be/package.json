{
  "name": "be",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env.local --watch --import tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env.local dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --max-warnings=0 \"src/**/*.ts\"",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "db:migrate": "node --env-file=.env.local --import tsx scripts/migrate.ts run",
    "db:revert": "node --env-file=.env.local --import tsx scripts/migrate.ts revert",
    "db:seed": "node --env-file=.env.local --import tsx scripts/seed-dev.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/typeorm": "^11.0.0",
    "@psstudio/shared": "workspace:*",
    "bullmq": "^5.76.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie": "^1.0.2",
    "diff": "^7.0.0",
    "ioredis": "^5.4.1",
    "jsonrepair": "^3.14.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.3",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.20",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/diff": "^7.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.9",
    "ioredis-mock": "^8.9.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9"
  }
}
